---
# TEMPLATE. Copy host-specific values into group_vars/all/local.yml (gitignored)
# and secrets into group_vars/all/vault.yml (ansible-vault encrypted, gitignored).
# See variablehelp.md for guidance. This .example file is committed; vars.yml holds
# only shared non-secret config.

# ---- host-specific (put REAL values in local.yml) ----
username: "<your username at setup>"
puid: "<id>"
pgid: "<id>"
ip_address: "<your server IP address>"
timezone: "<your timezone>"
domain: "<your domain name>"
local_network: "<your local network, e.g. 10.0.0.0/24>"
cloudflare_email: "<your cloudflare email>"
authelia_admin_mail: "<email for authelia>"
vpn_provider: "<your vpn provider>"
vpn_config: "<location of vpn server>"
minecraft_ops: "<your minecraft username(s), comma-separated, for server op>"

# ---- secrets (put REAL values in vault.yml, encrypted) ----
cloudflare_dns_api_token: "<cloudflare zone-scoped dns api token>"
traefik_basic_auth_hash: "<traefik hashed username and pass>"
jwt_secret: "<authelia jwt secret>"
authelia_sqlite_encryption_key: "<authelia encryption key>"
authelia_session_secret: "<authelia session secret>"
authelia_admin_argon2id_pass: "<authelia argon2 password>"
vaultwarden_admin_argon2id_pass: "<vaultwarden admin page argon2 password>"
wg_password: "<wireguard vpn password>"
codeserver_password: "<code server password>"
pihole_password: "<pihole password>"
mysql_password: "<mariadb password>"
sure_secret_key_base: "<sure rails SECRET_KEY_BASE — openssl rand -hex 64>"
sure_postgres_password: "<sure postgres role password — openssl rand -hex 24>"
vpn_username: "<vpn provider username>"
vpn_password: "<vpn provider password>"
user_password: "<your sudo password>"
diun_ntfy_topic: "<hard-to-guess ntfy topic for Diun update alerts>"
homarr_encryption_key: "<32-byte hex (openssl rand -hex 32) for homarr 1.x at-rest encryption>"

# ---- shared, non-secret (kept in vars.yml) ----
docker_dir: "/home/{{ username }}/docker_apps"
data_dir: "/home/{{ username }}/data"
shell: /usr/bin/fish
